rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Pillar 0: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers (Phase 3) ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Product Validation (Pillar 2) ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.category is string
          && data.priceNumber is number && data.priceNumber >= 0
          && data.image is string && data.image.size() >= 5
          && data.description is string;
    }

    // --- Order Validation (Pillar 2) ---
    function isValidOrder(data) {
      return data.customerEmail is string && data.customerEmail.size() <= 200
          && data.customerName is string && data.customerName.size() <= 200
          && data.items is list && data.items.size() > 0
          && data.total is number && data.total >= 0
          && data.paymentMethod is string
          && data.status == 'pending'
          && data.createdAt == request.time;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'Synclair.samson56@gmail.com' && request.auth.token.email_verified == true;
    }

    // --- Collection Routes (Phase 4) ---
    match /products/{productId} {
      allow read: if true;
      // Restricted to Admin
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      // Only Admin can view or update orders
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}
