{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A Ziva fashion product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["2-Piece Set", "3-Piece Set"] },
        "price": { "type": "string" },
        "priceNumber": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "details": { "type": "array", "items": { "type": "string" } },
        "tag": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "priceNumber", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "contact": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerEmail", "items", "total", "paymentMethod"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
